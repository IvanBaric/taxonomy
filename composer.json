{
  "name": "ivanbaric/taxonomy",
  "description": "Generic taxonomy package for Laravel with overridable models and optional tenancy support.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "ivanbaric/corexis": "dev-main as 1.0.0",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0",
    "illuminate/database": "^11.0 || ^12.0 || ^13.0"
  },
  "autoload": {
    "psr-4": {
      "IvanBaric\\Taxonomy\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IvanBaric\\Taxonomy\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
    "pestphp/pest": "^3.0 || ^4.0"
  },
  "extra": {
    "laravel": {
      "providers": [
        "IvanBaric\\Taxonomy\\TaxonomyServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "pest"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../corexis",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "stable",
  "prefer-stable": true
}
